eap {
    default_eap_type = tls
    tls-config tls-common {

        private_key_file = ${certdir}/key.pem
        certificate_file = ${certdir}/cert.pem
        ca_file = ${certdir}/roots.pem
        check_cert_cn = %{User-Name} 
        require_client_cert = yes
    }
    tls {
        tls = tls-common
    }
}
