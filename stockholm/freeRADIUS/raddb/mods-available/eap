eap {
    default_eap_type = tls
    tls-config tls-common {

        private_key_file = ${certdir}/server.key
        certificate_file = ${certdir}/server.crt
        ca_file = ${certdir}/ca.crt

        check_cert_cn = %{User-Name} 
        require_client_cert = yes
    }
    tls {
        tls = tls-common
    }
}